// --- BATCH CENSOR, AREA CONVERSION, & POSITIVES PER mm² ---
import qupath.lib.roi.RoiTools

final String CENSOR_CLASS = "Censor"
final String POSITIVE_TOKEN = "Positive"   // change if your positive class is named differently

// ---------- helpers ----------
boolean boxesOverlap(def r1, def r2) {
    if (r1 == null || r2 == null) return false
    double ax1 = r1.getBoundsX(), ay1 = r1.getBoundsY()
    double ax2 = ax1 + r1.getBoundsWidth(), ay2 = ay1 + r1.getBoundsHeight()
    double bx1 = r2.getBoundsX(), by1 = r2.getBoundsY()
    double bx2 = bx1 + r2.getBoundsWidth(), by2 = by1 + r2.getBoundsHeight()
    return !(ax2 < bx1 || bx2 < ax1 || ay2 < by1 || by2 < ay1)
}

// centroid-in-ROI test for detections (cheap & robust)
boolean centroidIn(def detROI, def targetROI) {
    if (detROI == null || targetROI == null) return false
    double cx = detROI.getCentroidX()
    double cy = detROI.getCentroidY()
    return targetROI.contains(cx, cy)
}

// ---------- calibration ----------
def server = getCurrentImageData().getServer()
def cal = server.getPixelCalibration()
boolean hasMicrons = cal != null && cal.hasPixelSizeMicrons()
double umPerPixelX = hasMicrons ? cal.getPixelWidthMicrons()  : 1.0
double umPerPixelY = hasMicrons ? cal.getPixelHeightMicrons() : 1.0
double um2PerPixel = umPerPixelX * umPerPixelY
double UM2_PER_MM2 = 1_000_000.0

// ---------- gather objects ----------
def anns = getAnnotationObjects()
def censorROIs = anns.findAll { it.getPathClass()?.toString() == CENSOR_CLASS }
                    .collect { it.getROI() }
def censorUnion = null
if (!censorROIs.isEmpty()) {
    censorUnion = censorROIs[0]
    for (int i = 1; i < censorROIs.size(); i++)
        censorUnion = RoiTools.combineROIs(censorUnion, censorROIs[i], RoiTools.CombineOp.ADD)
} else {
    println "No Censor masks found; nothing to subtract."
}

def targets = anns.findAll { a ->
    a.getPathClass()?.toString() != CENSOR_CLASS &&
    a.getName() != "Annotation (Rectangle)" &&
    a.getROI() != null
}

// Gather detections once
def allDets = getDetectionObjects()

int nChanged = 0
double totalCensored_um2 = 0.0

// ---------- main loop ----------
if (censorUnion != null) {
    for (def a : targets) {
        def roi = a.getROI()
        if (roi == null) continue
        if (!boxesOverlap(roi, censorUnion)) continue

        def newROI = RoiTools.combineROIs(roi, censorUnion, RoiTools.CombineOp.SUBTRACT)
        if (newROI == null) continue

        // area BEFORE/AFTER in µm² (robust to missing calibration)
        double areaBefore_px  = roi.getArea()
        double areaAfter_px   = newROI.getArea()
        if (areaAfter_px <= 0 || areaAfter_px > areaBefore_px) continue

        double areaBefore_um2 = areaBefore_px * um2PerPixel
        double areaAfter_um2  = areaAfter_px  * um2PerPixel
        double censored_um2   = areaBefore_um2 - areaAfter_um2
        double censoredPct    = 100.0 * censored_um2 / areaBefore_um2

        // apply censored geometry
        a.setROI(newROI)

        // compute positives inside UPDATED ROI
        // (filter by class name containing 'Positive' and centroid-in-ROI)
        int posCount = 0
        for (def d : allDets) {
            def pc = d.getPathClass()
            if (pc == null) continue
            def name = pc.toString()
            if (!name.contains(POSITIVE_TOKEN)) continue
            def dROI = d.getROI()
            if (dROI == null) continue
            // quick reject by bbox before precise centroid test
            if (!boxesOverlap(dROI, newROI)) continue
            if (centroidIn(dROI, newROI)) posCount++
        }

        // per-mm² metrics
        double areaAfter_mm2 = areaAfter_um2 / UM2_PER_MM2
        double posPerMm2     = (areaAfter_mm2 > 0) ? (posCount / areaAfter_mm2) : Double.NaN

        // write measurements in place
        def ml = a.getMeasurementList()
        ml.putMeasurement("Censored area µm^2", censored_um2)
        ml.putMeasurement("Censored % of ROI", censoredPct)
        ml.putMeasurement("Area after censor µm^2", areaAfter_um2)
        ml.putMeasurement("Area after censor mm^2", areaAfter_mm2)
        ml.putMeasurement("Positive detections (count)", posCount)
        ml.putMeasurement("Positive per mm^2", posPerMm2)

        nChanged++
        totalCensored_um2 += censored_um2
    }
}

// update UI/measurements and report
fireHierarchyUpdate()
println sprintf("Censoring complete. ROIs updated: %d, total censored area: %.0f µm^2", nChanged, totalCensored_um2)
